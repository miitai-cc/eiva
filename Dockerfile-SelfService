# ── Stage 1: Build ──────────────────────────────────────────────────────────
FROM rust:1.86-alpine AS builder

RUN apk add --no-cache build-base musl-dev openssl-dev cmake perl git

WORKDIR /build

# Cache dependencies: copy manifests first
COPY Cargo.toml Cargo.lock ./
COPY crates/eiva-core/Cargo.toml crates/eiva-core/
COPY crates/eiva-gateway/Cargo.toml crates/eiva-gateway/

# Create stub so cargo can resolve workspace
RUN mkdir -p crates/eiva-core/src crates/eiva-gateway/src && \
    echo "" > crates/eiva-core/src/lib.rs && \
    echo "fn main(){}" > crates/eiva-gateway/src/main.rs

# Pre-fetch and compile dependencies (cached unless manifest changes)
RUN cargo build --release -p eiva-gateway 2>/dev/null || true

# Copy real source
COPY crates/eiva-core/src crates/eiva-core/src
COPY crates/eiva-gateway/src crates/eiva-gateway/src
COPY vendor vendor

# Force recompile of source (deps cache is still valid)
RUN touch crates/eiva-core/src/lib.rs crates/eiva-gateway/src/main.rs

# Build release binary (statically linked against musl via Alpine)
RUN cargo build --release -p eiva-gateway && \
    cp target/release/eiva-gateway /build/eiva-gateway

# Strip debug symbols
RUN strip /build/eiva-gateway

# ── Build llama.cpp ─────────────────────────────────────────────────────────
WORKDIR /tmp
RUN git clone --depth 1 https://github.com/ggml-org/llama.cpp.git && \
    cd llama.cpp && \
    cmake -B build -DGGML_NATIVE=OFF -DLLAMA_CURL=OFF -DCMAKE_BUILD_TYPE=Release && \
    cmake --build build --config Release -j$(nproc) && \
    cp build/bin/llama-server /build/llama-server && \
    rm -rf /tmp/llama.cpp

# ── Stage 2: Runtime ────────────────────────────────────────────────────────
FROM alpine:3.21

# Runtime essentials + Node.js LTS + Python 3 + PDF tools
RUN apk add --no-cache \
    ca-certificates \
    curl \
    nodejs \
    npm \
    python3 \
    py3-pip \
    py3-virtualenv \
    poppler-utils \
    bash

# Python data processing packages: Excel, Word, PDF, numpy, pandas
RUN pip3 install --break-system-packages --no-cache-dir \
    numpy \
    pandas \
    openpyxl \
    python-docx \
    PyPDF2 \
    pdfplumber \
    xlrd \
    xlsxwriter \
    tabulate

# AI coding assistant CLIs
RUN npm install -g opencode @openai/codex

# ── Environment Variables ────────────────────────────────────────────────────
# Agent Mode:
#   AGENT_MODE          inner|codex|gemini|opencode (default: inner)
#
# llama.cpp:
#   LLAMA_MODEL_DIR     Model directory (default: /home/eiva/.config/eiva/models)
#   LLAMA_HOST          Bind address  (default: 0.0.0.0)
#   LLAMA_PORT          Bind port     (default: 8080)
#   LLAMA_EXTRA_ARGS    Extra args    (e.g. "-ngl 99 -c 4096")
#
# Gateway:
#   RUST_LOG            Log filter    (e.g. eiva=debug)
#   RUSTYCLAW_VAULT_PASSWORD  Vault password (cleared after read)
#   RUSTYCLAW_MODEL_API_KEY   LLM API key    (cleared after read)
#   RUSTYCLAW_RATE_LIMIT      Max tool calls per request (0 = unlimited)
#   OPENAI_API_KEY             OpenAI key
#   ANTHROPIC_API_KEY          Anthropic key
#   GOOGLE_API_KEY             Google AI key

# Create non-root user
RUN addgroup -S eiva && adduser -S -G eiva -h /home/eiva eiva

COPY --from=builder /build/eiva-gateway /usr/local/bin/eiva-gateway
COPY --from=builder /build/llama-server /usr/local/bin/llama-server

# Entrypoint script: starts llama-server in background, then eiva-gateway
COPY <<'EOF' /usr/local/bin/start.sh
#!/bin/bash
set -e

# Start llama-server if AGENT_MODE=inner or unset, and model dir exists
MODEL_DIR="${LLAMA_MODEL_DIR:-/home/eiva/.config/eiva/models}"
HOST="${LLAMA_HOST:-0.0.0.0}"
PORT="${LLAMA_PORT:-8080}"

if command -v llama-server >/dev/null 2>&1 && [ -d "$MODEL_DIR" ]; then
    echo "  Starting llama-server on ${HOST}:${PORT} (model dir: ${MODEL_DIR})"
    llama-server \
        --host "$HOST" \
        --port "$PORT" \
        --model-dir "$MODEL_DIR" \
        ${LLAMA_EXTRA_ARGS:-} &
    LLAMA_PID=$!
    # Wait briefly for server to start
    sleep 2
    if kill -0 $LLAMA_PID 2>/dev/null; then
        echo "  llama-server started (PID: $LLAMA_PID)"
    else
        echo "  llama-server failed to start"
    fi
fi

# Start eiva-gateway
exec eiva-gateway "$@"
EOF
RUN chmod +x /usr/local/bin/start.sh

RUN mkdir -p /home/eiva/.config/eiva && \
    chown -R eiva:eiva /home/eiva

USER eiva
WORKDIR /home/eiva

EXPOSE 3000
EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -sf http://localhost:3000/health || exit 1

ENTRYPOINT ["/usr/local/bin/start.sh"]
CMD ["run", "--ssh-listen", "0.0.0.0:3000"]
