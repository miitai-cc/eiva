# ── Eiva Gateway Environment Variables ──────────────────────────────────────
# Copy this file to `.env` and fill in the values.
# `.env` is loaded automatically at startup (dotenvy) and must NOT be committed.

# ── Logging ─────────────────────────────────────────────────────────────────
# Log level filter (tracing syntax, e.g. "debug", "eiva=debug,hyper=warn")
# RUST_LOG=eiva=info,warn

# ── Vault ───────────────────────────────────────────────────────────────────
# Password for the encrypted secrets vault (injected by launcher, cleared
# from env after read).  Leave empty or unset if vault is not password-protected.
# RUSTYCLAW_VAULT_PASSWORD=

# ── Model ───────────────────────────────────────────────────────────────────
# API key for the LLM provider (injected by launcher, cleared from env after
# read).  If unset, the gateway resolves the key from the secrets vault.
# RUSTYCLAW_MODEL_API_KEY=

# ── Rate Limiting ───────────────────────────────────────────────────────────
# Max tool invocations per request (0 = unlimited).
# RUSTYCLAW_RATE_LIMIT=0

# ── SSH ─────────────────────────────────────────────────────────────────────
# Username reported during SSH authentication handshake.
# SSH_USER=

# ── Self-Service Frontend ───────────────────────────────────────────────────
# Port for the gateway REST API (default: 39999).
# EIVA_GATEWAY_PORT=39999

# ── Cron / Scheduler Mode ──────────────────────────────────────────────────
# Scheduler backend. Options:
#   Inner    — use Eiva's built-in SQLite-backed scheduler
#   Openclaw — delegate schedule creation/execution to OpenClaw integration
#   hermess  — delegate schedule creation/execution to hermess integration
#   OS       — generate/use operating-system scheduler config (for example cron/launchd)
# Each mode can later load its own config file.
# CRON_TYPE=Inner
# Optional overrides:
# CRON_CONFIG_DIR=config/cron
# CRON_CONFIG_PATH=

# ── Agent Mode ──────────────────────────────────────────────────────────────
# Agent execution backend. Options:
#   inner    — built-in Rust agent loop (default), uses configured model
#              provider directly (no external CLI required)
#   codex    — OpenAI Codex CLI (requires `codex` installed)
#   gemini   — Google Gemini CLI (requires `gemini` installed)
#   opencode — opencode CLI (requires `opencode` installed)
# AGENT_MODE=inner

# ── llama.cpp (local inference) ─────────────────────────────────────────────
# llama-server is auto-started by the Docker entrypoint when LLAMA_MODEL_DIR
# exists and contains model files.  Set LLAMA_HOST/PORT to control binding.
# LLAMA_MODEL_DIR=/home/eiva/.config/eiva/models
# LLAMA_HOST=0.0.0.0
# LLAMA_PORT=8080
# LLAMA_EXTRA_ARGS=
