# ── Eiva Gateway Environment Variables ──────────────────────────────────────
# Copy this file to `.env` and fill in the values.
# `.env` is loaded automatically at startup (dotenvy) and must NOT be committed.

# ── Logging ─────────────────────────────────────────────────────────────────
# Log level filter (tracing syntax, e.g. "debug", "eiva=debug,hyper=warn")
# RUST_LOG=eiva=info,warn

# ── Vault ───────────────────────────────────────────────────────────────────
# Password for the encrypted secrets vault (injected by launcher, cleared
# from env after read).  Leave empty or unset if vault is not password-protected.
# RUSTYCLAW_VAULT_PASSWORD=

# ── Model ───────────────────────────────────────────────────────────────────
# API key for the LLM provider (injected by launcher, cleared from env after
# read).  If unset, the gateway resolves the key from the secrets vault.
# RUSTYCLAW_MODEL_API_KEY=

# ── Rate Limiting ───────────────────────────────────────────────────────────
# Max tool invocations per request (0 = unlimited).
# RUSTYCLAW_RATE_LIMIT=0

# ── SSH ─────────────────────────────────────────────────────────────────────
# Username reported during SSH authentication handshake.
# SSH_USER=

# ── Self-Service Frontend ───────────────────────────────────────────────────
# Port for the gateway REST API (default: 39999).
# EIVA_GATEWAY_PORT=39999
